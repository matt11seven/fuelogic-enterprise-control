# Configurações do Servidor
PORT=3001

# Configurações do PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fuelogic_enterprise
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Configurações JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Credenciais Master (para fallback e admin inicial)
MASTER_USERNAME=admin
MASTER_PASSWORD=secure_master_password
MASTER_API_KEY=secure_master_api_key

# Sophia (substitui fluxo n8n localmente)
SOPHIA_OPENAI_API_KEY=your_openai_key_here
SOPHIA_MODEL=gpt-4.1-mini
SOPHIA_MEMORY_WINDOW=30
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=http://localhost:8080
OPENROUTER_APP_TITLE=Fuelogic Sophia
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# Canal de saída (equivalente ao HTTP Request do n8n)
SOPHIA_OUTBOUND_URL=https://your-whatsapp-provider/message/sendText/CM
SOPHIA_OUTBOUND_API_KEY=your_channel_api_key_here

# Segurança do webhook de entrada e auto-reply
SOPHIA_INBOUND_WEBHOOK_KEY=your_inbound_webhook_key_here
SOPHIA_AUTO_REPLY=false

# Sync automático GasMobile (background)
GASMOBILE_AUTO_SYNC_ENABLED=true
GASMOBILE_AUTO_SYNC_INTERVAL_MS=1200000
GASMOBILE_AUTO_SYNC_RUN_ON_STARTUP=true
